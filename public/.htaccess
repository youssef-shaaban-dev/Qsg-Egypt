# 🚀 Prevent LiteSpeed and browser caching of index.html so users always get the latest build
<Files "index.html">
  <IfModule LiteSpeed>
    RewriteEngine On
    RewriteRule .* - [E=Cache-Control:no-cache]
  </IfModule>

  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
  </IfModule>
</Files>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^index\.html$ - [L]

  # If the file or directory exists, use it directly
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Otherwise always serve index.html (SPA)
  RewriteRule . /index.html [L]
</IfModule>
